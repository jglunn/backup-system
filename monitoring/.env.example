# Copy to .env and fill in. docker-compose loads this via env_file:.
# NEVER commit a real .env.

# Grafana admin bootstrap password — change on first login.
GF_SECURITY_ADMIN_PASSWORD=please-change-me

# SMTP — used for Grafana-managed alert notifications. Example uses
# Gmail with an app password; swap in your provider's values.
GF_SMTP_ENABLED=true
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=your-email@gmail.com
GF_SMTP_PASSWORD=your-app-password
GF_SMTP_FROM_ADDRESS=your-email@gmail.com
GF_SMTP_FROM_NAME=Backup Monitor
GF_SMTP_SKIP_VERIFY=false
